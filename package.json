{
  "name": "musical-choir-website",
  "version": "4.0.0",
  "description": "Сайт Broadway Guitardo — Vue + Express",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "build": "npm install --prefix client && npm run build --prefix client",
    "render-build": "npm install && npm run build",
    "dev:api": "node backend/server.js",
    "dev:client": "npm run dev --prefix client",
    "dev": "echo Запустите: npm run dev:api и npm run dev:client в двух терминалах",
    "init-auth": "node scripts/init-auth.js"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.34.3"
  }
}
