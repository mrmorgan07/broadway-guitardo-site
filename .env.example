# Порт сервера
PORT=3000

# Пароль для входа в админку (/admin.html)
# ОБЯЗАТЕЛЬНО смените перед публикацией!
ADMIN_PASSWORD=admin123

# Секрет для сессионных токенов (любая длинная случайная строка)
SESSION_SECRET=change-me-to-random-string

# --- База данных (Turso / libSQL) ---
# Локально можно НЕ задавать: сервер сам создаст файл backend/data/site.db.
# В проде (Render) задайте оба значения из дашборда Turso — тогда правки
# из админки переживают редеплой (файловая система Render эфемерна).
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token
